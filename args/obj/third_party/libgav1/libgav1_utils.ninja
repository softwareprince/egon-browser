defines = -DDCHECK_ALWAYS_ON=1 -DUSE_UDEV -DUSE_AURA=1 -DUSE_GLIB=1 -DUSE_OZONE=1 -D_FILE_OFFSET_BITS=64 -D_LARGEFILE_SOURCE -D_LARGEFILE64_SOURCE -D_GNU_SOURCE -DCR_CLANG_REVISION=\"llvmorg-16-init-8697-g60809cd2-1\" -DCOMPONENT_BUILD -DCR_LIBCXX_REVISION=4218f3525ad438b22b0e173d963515a09d143398 -D_LIBCPP_ENABLE_ASSERTIONS_DEFAULT=1 -D_LIBCPP_AVAILABILITY_CUSTOM_VERBOSE_ABORT_PROVIDED=1 -DCR_SYSROOT_KEY=20220331T153654Z-0 -D_DEBUG -DDYNAMIC_ANNOTATIONS_ENABLED=1 -DLIBGAV1_MAX_BITDEPTH=10 -DLIBGAV1_THREADPOOL_USE_STD_MUTEX -DLIBGAV1_ENABLE_LOGGING=0 -DLIBGAV1_PUBLIC=
include_dirs = -I.. -Igen -I../buildtools/third_party/libc++ -I../third_party/libgav1/src -I../third_party/libgav1/src/src
cflags = -fno-delete-null-pointer-checks -fno-ident -fno-strict-aliasing --param=ssp-buffer-size=4 -fstack-protector -funwind-tables -fPIC -pthread -fcolor-diagnostics -fmerge-all-constants -fcrash-diagnostics-dir=../tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -ffp-contract=off -fcomplete-member-pointers -m64 -msse3 -Wno-builtin-macro-redefined -D__DATE__= -D__TIME__= -D__TIMESTAMP__= -ffile-compilation-dir=. -no-canonical-prefixes -ftrivial-auto-var-init=pattern -O0 -fno-omit-frame-pointer -gdwarf-4 -g2 -gdwarf-aranges -gsplit-dwarf -ggnu-pubnames -Xclang -fuse-ctor-homing -fvisibility=hidden -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-ipc -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Werror -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wenum-compare-conditional -Wno-ignored-pragma-optimize -Wno-deprecated-builtins -Wno-bitfield-constant-conversion
cflags_cc = -Wno-undefined-bool-conversion -Wno-tautological-undefined-compare -std=c++20 -Wno-trigraphs -gsimple-template-names -fno-exceptions -fno-rtti -nostdinc++ -isystem../buildtools/third_party/libc++/trunk/include -isystem../buildtools/third_party/libc++abi/trunk/include --sysroot=../build/linux/debian_bullseye_amd64-sysroot -fvisibility-inlines-hidden
label_name = libgav1_utils
target_out_dir = obj/third_party/libgav1
target_output_name = libgav1_utils

build obj/third_party/libgav1/libgav1_utils/bit_reader.o: cxx ../third_party/libgav1/src/src/utils/bit_reader.cc
  source_file_part = bit_reader.cc
  source_name_part = bit_reader
build obj/third_party/libgav1/libgav1_utils/block_parameters_holder.o: cxx ../third_party/libgav1/src/src/utils/block_parameters_holder.cc
  source_file_part = block_parameters_holder.cc
  source_name_part = block_parameters_holder
build obj/third_party/libgav1/libgav1_utils/constants.o: cxx ../third_party/libgav1/src/src/utils/constants.cc
  source_file_part = constants.cc
  source_name_part = constants
build obj/third_party/libgav1/libgav1_utils/cpu.o: cxx ../third_party/libgav1/src/src/utils/cpu.cc
  source_file_part = cpu.cc
  source_name_part = cpu
build obj/third_party/libgav1/libgav1_utils/entropy_decoder.o: cxx ../third_party/libgav1/src/src/utils/entropy_decoder.cc
  source_file_part = entropy_decoder.cc
  source_name_part = entropy_decoder
build obj/third_party/libgav1/libgav1_utils/executor.o: cxx ../third_party/libgav1/src/src/utils/executor.cc
  source_file_part = executor.cc
  source_name_part = executor
build obj/third_party/libgav1/libgav1_utils/logging.o: cxx ../third_party/libgav1/src/src/utils/logging.cc
  source_file_part = logging.cc
  source_name_part = logging
build obj/third_party/libgav1/libgav1_utils/raw_bit_reader.o: cxx ../third_party/libgav1/src/src/utils/raw_bit_reader.cc
  source_file_part = raw_bit_reader.cc
  source_name_part = raw_bit_reader
build obj/third_party/libgav1/libgav1_utils/segmentation.o: cxx ../third_party/libgav1/src/src/utils/segmentation.cc
  source_file_part = segmentation.cc
  source_name_part = segmentation
build obj/third_party/libgav1/libgav1_utils/segmentation_map.o: cxx ../third_party/libgav1/src/src/utils/segmentation_map.cc
  source_file_part = segmentation_map.cc
  source_name_part = segmentation_map
build obj/third_party/libgav1/libgav1_utils/threadpool.o: cxx ../third_party/libgav1/src/src/utils/threadpool.cc
  source_file_part = threadpool.cc
  source_name_part = threadpool

build obj/third_party/libgav1/libgav1_utils.stamp: stamp obj/third_party/libgav1/libgav1_utils/bit_reader.o obj/third_party/libgav1/libgav1_utils/block_parameters_holder.o obj/third_party/libgav1/libgav1_utils/constants.o obj/third_party/libgav1/libgav1_utils/cpu.o obj/third_party/libgav1/libgav1_utils/entropy_decoder.o obj/third_party/libgav1/libgav1_utils/executor.o obj/third_party/libgav1/libgav1_utils/logging.o obj/third_party/libgav1/libgav1_utils/raw_bit_reader.o obj/third_party/libgav1/libgav1_utils/segmentation.o obj/third_party/libgav1/libgav1_utils/segmentation_map.o obj/third_party/libgav1/libgav1_utils/threadpool.o
