defines = -DFLAC__OVERFLOW_DETECT -DVERSION=\"1.3.1\" -DHAVE_LROUND -DHAVE_INTTYPES_H -DDCHECK_ALWAYS_ON=1 -DUSE_UDEV -DUSE_AURA=1 -DUSE_GLIB=1 -DUSE_OZONE=1 -D_FILE_OFFSET_BITS=64 -D_LARGEFILE_SOURCE -D_LARGEFILE64_SOURCE -D_GNU_SOURCE -DCR_CLANG_REVISION=\"llvmorg-16-init-8697-g60809cd2-1\" -DCOMPONENT_BUILD -DCR_LIBCXX_REVISION=4218f3525ad438b22b0e173d963515a09d143398 -D_LIBCPP_ENABLE_ASSERTIONS_DEFAULT=1 -D_LIBCPP_AVAILABILITY_CUSTOM_VERBOSE_ABORT_PROVIDED=1 -DCR_SYSROOT_KEY=20220331T153654Z-0 -D_DEBUG -DDYNAMIC_ANNOTATIONS_ENABLED=1 -DFLAC__NO_DLL
include_dirs = -I../third_party/flac/include -I../third_party/flac/src/libFLAC/include -I.. -Igen -I../buildtools/third_party/libc++
cflags = -fno-delete-null-pointer-checks -fno-ident -fno-strict-aliasing --param=ssp-buffer-size=4 -fstack-protector -funwind-tables -fPIC -pthread -fcolor-diagnostics -fmerge-all-constants -fcrash-diagnostics-dir=../tools/clang/crashreports -mllvm -instcombine-lower-dbg-declare=0 -ffp-contract=off -fcomplete-member-pointers -m64 -msse3 -Wno-builtin-macro-redefined -D__DATE__= -D__TIME__= -D__TIMESTAMP__= -ffile-compilation-dir=. -no-canonical-prefixes -ftrivial-auto-var-init=pattern -O0 -fno-omit-frame-pointer -gdwarf-4 -g2 -gdwarf-aranges -gsplit-dwarf -ggnu-pubnames -Xclang -fuse-ctor-homing -fvisibility=hidden -Xclang -add-plugin -Xclang find-bad-constructs -Xclang -plugin-arg-find-bad-constructs -Xclang raw-ref-template-as-trivial-member -Xclang -plugin-arg-find-bad-constructs -Xclang check-ipc -Wheader-hygiene -Wstring-conversion -Wtautological-overlap-compare -Wno-conversion -Wno-unused-const-variable -Werror -Wall -Wno-unused-variable -Wno-c++11-narrowing -Wno-unused-but-set-variable -Wno-misleading-indentation -Wno-missing-field-initializers -Wno-unused-parameter -Wno-psabi -Wloop-analysis -Wno-unneeded-internal-declaration -Wenum-compare-conditional -Wno-ignored-pragma-optimize -Wno-deprecated-builtins -Wno-bitfield-constant-conversion
cflags_c = -std=c11 --sysroot=../build/linux/debian_bullseye_amd64-sysroot
label_name = flac
target_out_dir = obj/third_party/flac
target_output_name = flac

build obj/third_party/flac/flac/alloc.o: cc ../third_party/flac/src/libFLAC/alloc.c
  source_file_part = alloc.c
  source_name_part = alloc
build obj/third_party/flac/flac/bitmath.o: cc ../third_party/flac/src/libFLAC/bitmath.c
  source_file_part = bitmath.c
  source_name_part = bitmath
build obj/third_party/flac/flac/bitreader.o: cc ../third_party/flac/src/libFLAC/bitreader.c
  source_file_part = bitreader.c
  source_name_part = bitreader
build obj/third_party/flac/flac/bitwriter.o: cc ../third_party/flac/src/libFLAC/bitwriter.c
  source_file_part = bitwriter.c
  source_name_part = bitwriter
build obj/third_party/flac/flac/cpu.o: cc ../third_party/flac/src/libFLAC/cpu.c
  source_file_part = cpu.c
  source_name_part = cpu
build obj/third_party/flac/flac/crc.o: cc ../third_party/flac/src/libFLAC/crc.c
  source_file_part = crc.c
  source_name_part = crc
build obj/third_party/flac/flac/fixed.o: cc ../third_party/flac/src/libFLAC/fixed.c
  source_file_part = fixed.c
  source_name_part = fixed
build obj/third_party/flac/flac/float.o: cc ../third_party/flac/src/libFLAC/float.c
  source_file_part = float.c
  source_name_part = float
build obj/third_party/flac/flac/format.o: cc ../third_party/flac/src/libFLAC/format.c
  source_file_part = format.c
  source_name_part = format
build obj/third_party/flac/flac/lpc.o: cc ../third_party/flac/src/libFLAC/lpc.c
  source_file_part = lpc.c
  source_name_part = lpc
build obj/third_party/flac/flac/md5.o: cc ../third_party/flac/src/libFLAC/md5.c
  source_file_part = md5.c
  source_name_part = md5
build obj/third_party/flac/flac/memory.o: cc ../third_party/flac/src/libFLAC/memory.c
  source_file_part = memory.c
  source_name_part = memory
build obj/third_party/flac/flac/stream_decoder.o: cc ../third_party/flac/src/libFLAC/stream_decoder.c
  source_file_part = stream_decoder.c
  source_name_part = stream_decoder
build obj/third_party/flac/flac/stream_encoder.o: cc ../third_party/flac/src/libFLAC/stream_encoder.c
  source_file_part = stream_encoder.c
  source_name_part = stream_encoder
build obj/third_party/flac/flac/stream_encoder_framing.o: cc ../third_party/flac/src/libFLAC/stream_encoder_framing.c
  source_file_part = stream_encoder_framing.c
  source_name_part = stream_encoder_framing
build obj/third_party/flac/flac/window.o: cc ../third_party/flac/src/libFLAC/window.c
  source_file_part = window.c
  source_name_part = window

build obj/third_party/flac/flac.stamp: stamp obj/third_party/flac/flac/alloc.o obj/third_party/flac/flac/bitmath.o obj/third_party/flac/flac/bitreader.o obj/third_party/flac/flac/bitwriter.o obj/third_party/flac/flac/cpu.o obj/third_party/flac/flac/crc.o obj/third_party/flac/flac/fixed.o obj/third_party/flac/flac/float.o obj/third_party/flac/flac/format.o obj/third_party/flac/flac/lpc.o obj/third_party/flac/flac/md5.o obj/third_party/flac/flac/memory.o obj/third_party/flac/flac/stream_decoder.o obj/third_party/flac/flac/stream_encoder.o obj/third_party/flac/flac/stream_encoder_framing.o obj/third_party/flac/flac/window.o
