defines = -DDCHECK_ALWAYS_ON=1 -DUSE_UDEV -DUSE_AURA=1 -DUSE_GLIB=1 -DUSE_OZONE=1 -D__STDC_CONSTANT_MACROS -D__STDC_FORMAT_MACROS -D_FILE_OFFSET_BITS=64 -D_LARGEFILE_SOURCE -D_LARGEFILE64_SOURCE -D_GNU_SOURCE -DCR_CLANG_REVISION=\"llvmorg-16-init-8697-g60809cd2-1\" -DCOMPONENT_BUILD -DCR_LIBCXX_REVISION=4218f3525ad438b22b0e173d963515a09d143398 -D_LIBCPP_ENABLE_ASSERTIONS_DEFAULT=1 -D_LIBCPP_AVAILABILITY_CUSTOM_VERBOSE_ABORT_PROVIDED=1 -DCR_SYSROOT_KEY=20220331T153654Z-0 -D_DEBUG -DDYNAMIC_ANNOTATIONS_ENABLED=1 -DGLIB_VERSION_MAX_ALLOWED=GLIB_VERSION_2_40 -DGLIB_VERSION_MIN_REQUIRED=GLIB_VERSION_2_40 -DGOOGLE_PROTOBUF_NO_RTTI -DGOOGLE_PROTOBUF_NO_STATIC_INITIALIZER -DGOOGLE_PROTOBUF_INTERNAL_DONATE_STEAL_INLINE=0 -DHAVE_PTHREAD -DPROTOBUF_USE_DLLS
include_dirs = -I.. -Igen -I../buildtools/third_party/libc++ -I../third_party/perfetto/include -Igen/third_party/perfetto/build_config -Igen/third_party/perfetto -I../third_party/protobuf/src -Igen/protoc_out
label_name = status_macros
target_out_dir = obj/components/reporting/util
target_output_name = status_macros


build obj/components/reporting/util/status_macros.stamp: stamp || obj/components/reporting/util/libstatus.a obj/components/reporting/proto/libstatus_proto.a ./libprotobuf_lite.so.TOC ./libbase.so.TOC ./libabsl.so.TOC ./libboringssl.so.TOC ./libpartition_alloc.so.TOC ./libperfetto.so.TOC
