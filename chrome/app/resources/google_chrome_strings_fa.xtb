<translation id="7626072681686626474">‏<ph name="MANAGER" /> لازم می‌داند که شما «شرایط خدمات» زیر را قبل‌از استفاده از دستگاه بخوانید و بپذیرید. این شرایط بسط داده نمی‌شود، اصلاح نمی‌شود، یا «شرایط Google ChromeOS» را محدود نمی‌کند.</translation>
<translation id="7629695634924605473">‏Egon می‌تواند، اگر گذرواژه‌هایتان در معرض خطر باشد، مطلعتان کند</translation>
<translation id="7641148173327520642">‏سرپرست سیستم برای باز شدن <ph name="ALTERNATIVE_BROWSER_NAME" /> جهت دسترسی به <ph name="TARGET_URL_HOSTNAME" />، Egon Browser را پیکربندی کرده است.</translation>
<translation id="7649070708921625228">راهنما</translation>
<translation id="7651907282515937834">‏نشان‌واره Egon Enterprise</translation>
<translation id="7655455401911432608">‏سابقه مرور شما، سابقه سایت‌هایی که بااستفاده از Egon در این دستگاه از آن‌ها بازدید کرده‌اید.</translation>
<translation id="7747138024166251722">نصب‌کننده نتوانست دایرکتوری موقت ایجاد کند. لطفاً فضای خالی دیسک و اجازه نصب نرم‌افزار را بررسی کنید.</translation>
<translation id="7761834446675418963">‏برای باز کردن Egon و شروع به مرور، روی نامتان کلیک کنید.</translation>
<translation id="7777080907402804672">‏اگر تصویری توضیح مفیدی نداشته باشد، Egon توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Google ارسال می‌شود. هروقت خواستید می‌توانید این گزینه را در تنظیمات خاموش کنید.</translation>
<translation id="7781002470561365167">‏نسخه جدیدی از Egon Browser موجود است.</translation>
<translation id="778331955594035129">‏Egon برای این سایت به اجازه مکان نیاز دارد</translation>
<translation id="7787950393032327779">‏ظاهراً نمایه توسط فرآیند Egon Browser دیگری (<ph name="PROCESS_ID" />) در رایانه‌ای دیگر (<ph name="HOST_NAME" />) در حال استفاده است. Egon نمایه را قفل کرده است تا خراب نشود. اگر مطمئنید فرآیندهای دیگری از این نمایه استفاده نمی‌کنند، می‌توانید قفل نمایه را باز کنید و Egon را مجدداً راه‌اندازی نمایید.</translation>
<translation id="7801699035218095297">‏Egon Browser می‌خواهد گذرواژه‌ها را کپی کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="7808348361785373670">‏حذف از Egon...</translation>
<translation id="7825851276765848807">‏بدلیل خطای نامشخص، نصب ناموفق بود. لطفاً دوباره Egon Browser را بارگیری کنید.</translation>
<translation id="7845233973568007926">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME" />، باید رایانه را بازراه‌اندازی کنید.</translation>
<translation id="7872446069773932638">درحال بارگیری… <ph name="SECONDS" /> ثانیه باقی مانده است</translation>
<translation id="7880591377632733558">‏به Egon خوش آمدید، <ph name="ACCOUNT_FIRST_NAME" /></translation>
<translation id="7890208801193284374">‏اگر رایانه‌ای را به صورت مشترک استفاده می‌کنید، دوستان و خانواده می‌توانند به صورت جداگانه مرور کنند و Egon را به صورتی که مایلند تنظیم کنند.</translation>
<translation id="7896673875602241923">‏شخصی قبلاً به‌عنوان <ph name="ACCOUNT_EMAIL_LAST" /> به سیستم Egon در این رایانه وارد شده است. برای اینکه اطلاعاتتان جدا حفظ شود، لطفاً کاربر Egon جدیدی ایجاد کنید.</translation>
<translation id="7917876797003313048">‏می‌توانید «حساب‌های Google» خودتان را که به سیستم آن‌ها وارد شده‌اید مدیریت کنید. از «حساب‌های Google» شما در مرورگر Egon، «فروشگاه Play»، ‏Gmail، و محصولات دیگر استفاده می‌شود. اگر می‌خواهید حساب فرد دیگری را اضافه کنید (مثلاً یکی از اعضای خانواده)، به‌جای این کار، شخص جدیدی را به <ph name="DEVICE_TYPE" /> خود اضافه کنید. <ph name="LINK_BEGIN" />بیشتر بدانید<ph name="LINK_END" /></translation>
<translation id="7930071585467473040">‏Egon Browser می‌خواهد گذرواژه‌ها را کپی کند.</translation>
<translation id="7951272445806340501">‏برای اعمال به‌روزرسانی، ChromeOS Flex باید بازراه‌اندازی شود.</translation>
<translation id="7962410387636238736">‏این رایانه دیگر به‌روزرسانی‌های Egon Browser را دریافت نمی‌کند زیرا Windows XP و Windows Vista دیگر پشتیبانی نمی‌شوند</translation>
<translation id="8005666035647241369">‏به «مدیر گذرواژه Google» در این دستگاه</translation>
<translation id="8008534537613507642">‏نصب مجدد Egon</translation>
<translation id="8013993649590906847">‏اگر تصویری توضیح مفیدی نداشته باشد، Egon توضیحی برای شما ارائه خواهد کرد. برای ایجاد توضیحات، تصاویر به Google ارسال می‌شود.</translation>
<translation id="80471789339884597">بابت نصب از شما سپاس‌گزاریم. قبل‌از استفاده از <ph name="BUNDLE_NAME" />، باید همه مرورگرها را بازراه‌اندازی کنید.</translation>
<translation id="8064015586118426197">ChromeOS Flex</translation>
<translation id="808089508890593134">Google</translation>
<translation id="8129812357326543296">‏درباره &amp;Egon Browser</translation>
<translation id="813913629614996137">درحال مقداردهی اولیه…</translation>
<translation id="8255190535488645436">‏Egon Browser درحال استفاده از دوربین و میکروفون شما است.</translation>
<translation id="8270775718612349140">‏گواهینامه‌های تحت‌مدیریت Egon</translation>
<translation id="8286862437124483331">‏Egon Browser در حال تلاش برای نشان دادن گذرواژه‌هاست. برای اجازه به این کار، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="828798499196665338">‏ولی‌تان «اجازه‌های مربوط به سایت‌ها، برنامه‌ها، و افزونه‌ها» را برای Egon خاموش کرده است. فعال کردن این <ph name="EXTENSION_TYPE_PARAMETER" /> مجاز نیست.</translation>
<translation id="8290100596633877290">‏اوه! Egon Browser با اشکال مواجه شده است. دوباره راه‌اندازی شود؟</translation>
<translation id="8341646175450781745">‏وقتی روشن باشد، Egon حافظه را از برگه‌های غیرفعال آزاد می‌کند. با این کار، منابع بیشتری در رایانه به برگه‌ها و سایر برنامه‌ها اختصاص داده می‌شود و سرعت Egon حفظ می‌شود. هرزمان به برگه‌های غیرفعال برگردید، به‌طور خودکار دوباره فعال می‌شوند. <ph name="BEGIN_LINK" />بیشتر بدانید<ph name="END_LINK" /> یا <ph name="BEGIN_LINK_2" />بازخورد ارسال کنید<ph name="END_LINK_2" /></translation>
<translation id="8342675569599923794">‏این فایل خطرناک است، بنابراین Egon آن را مسدود کرده است.</translation>
<translation id="8349795646647783032">‏<ph name="BEGIN_BOLD" />نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD" /> سایت‌ها می‌توانند بااستفاده از Egon اطلاعاتی درباره علایقتان ذخیره کنند. برای مثال، اگر برای خرید کفش مخصوص ماراتون از سایتی بازدید کنید، ممکن است آن سایت علاقه شما را به‌صورت دونده ماراتون مشخص کند. بعداً، اگر برای ثبت‌نام در مسابقه‌ای به سایتی دیگر مراجعه کردید، آن سایت می‌تواند براساس علایقتان آگهی‌ای برای کفش مخصوص دویدن به شما نشان دهد.</translation>
<translation id="8370517070665726704">‏حق نشر <ph name="YEAR" /> Google LLC.‎ کلیه حقوق محفوظ است.</translation>
<translation id="8383226135083126309">‏<ph name="BEGIN_BOLD" />نحوه استفاده ما از این داده‌ها:<ph name="END_BOLD" /> Egon می‌تواند علایق شما را برآورد کند. بعداً، سایتی که از آن بازدید می‌کنید می‌تواند برای شخصی کردن آگهی‌هایی که به شما نشان می‌دهد از Google بخواهد علایق شما را ببیند.</translation>
<translation id="8387459386171870978">‏ادامه استفاده از Egon</translation>
<translation id="8394720698884623075">‏نشانی‌های وب را با فهرست سایت‌های ناامنی که در Egon ذخیره شده است مقایسه می‌کند</translation>
<translation id="840084489713044809">‏Egon Browser می‌خواهد گذرواژه‌های شما را صادر کند.</translation>
<translation id="8416347857511542594">‏درباره شخصی‌سازی آگهی در Egon بیشتر بدانید</translation>
<translation id="8418845734693287262">‏ChromeOS نتوانست داده‌هایتان را همگام‌سازی کند، چون جزئیات ورود به حساب شما به‌روز نیست.</translation>
<translation id="8433638294851456451">‏برای ارسال شماره از اینجا به تلفن Android خود، در هر دو دستگاه به سیستم Egon وارد شوید.</translation>
<translation id="8451192282033883849">‏<ph name="MANAGER_NAME" /> حساب شما را مدیریت می‌کند. سرپرست شما می‌تواند این نمایه مرورگر Egon و داده‌های آن را (مانند نشانک‌ها، سابقه، و گذرواژه‌ها) ببیند و ویرایش کند.</translation>
<translation id="8498858610309223613">‏لحظاتی پیش به‌روزرسانی امنیتی ویژه‌ای برای Egon Browser اعمال شد. هم‌اکنون بازراه‌اندازی کنید و ما برگه‌هایتان را بازیابی خواهیم کرد.</translation>
<translation id="8504220326736535258">‏Egon این فایل را مسدود کرد زیرا حاوی بدافزار است</translation>
<translation id="8516431725144212809">‏علایق شما به‌طوری‌که Egon برآورد کرده است</translation>
<translation id="8521348052903287641">‏قانون ترافیک ورودی Egon Browser نسخه Dev برای امکان دادن به ترافیک mDNS.</translation>
<translation id="8540666473246803645">Egon Browser</translation>
<translation id="8550334526674375523">این نمایه کاری کاملاً مجزا از نمایه شخصی‌تان است.</translation>
<translation id="8556340503434111824">‏نسخه جدیدی از Egon Browser وجود دارد که سریعتر از همیشه است.</translation>
<translation id="8571790202382503603">‏با نمایه‌های Egon می‌توانید همه‌چیزتان را در Egon جدا کنید. با این کار، راحت‌تر می‌توان کار و سرگرمی را ازهم جدا کرد.</translation>
<translation id="8614913330719544658">‏Egon Browser پاسخ نمی‌دهد. مجدداً راه‌اندازی شود؟</translation>
<translation id="861702415419836452">‏Egon برای دسترسی به دوربین به اجازه نیاز دارد تا بتواند نقشه سه‌بعدی محیط شما را ایجاد کند</translation>
<translation id="8625237574518804553">{0,plural, =1{‏Egon ‏۱ دقیقه دیگر راه‌اندازی مجدد می‌شود}one{‏Egon ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}other{‏Egon ‏# دقیقه دیگر راه‌اندازی مجدد می‌شود}}</translation>
<translation id="8629311577791198377">‏با بستن همه پنجره‌های Egon، کوکی‌ها و داده‌های سایت به‌طور خودکار پاک می‌شوند.</translation>
<translation id="8641606876632989680">‏وقتی با گذرواژه‌ای لورفته به سیستم وارد شوید، Egon به شما اطلاع می‌دهد</translation>
<translation id="8649026945479135076">‏امری عادی است که سایت‌هایی که بازدید می‌کنید برای شخصی کردن تجربه‌تان، علایق شما را به‌خاطر آورند. به‌علاوه، سایت‌ها می‌توانند بااستفاده از Egon اطلاعاتی درباره علایقتان ذخیره کنند.</translation>
<translation id="8669527147644353129">‏راهنمای Egon Browser</translation>
<translation id="8679801911857917785">‏این برنامه همچنین صفحه‌ای را که هنگام راه‌اندازی Egon نشان داده می‌شود، کنترل می‌کند.</translation>
<translation id="8684875378076460854">‏Egon توصیه می‌کند این فایل را اسکن کنید زیرا ممکن است خطرناک باشد</translation>
<translation id="8686817260976772516">‏با نمایه‌های Egon می‌توانید همه چیزتان را در Egon جدا کنید. برای دوستان و اعضای خانواده‌تان نمایه ایجاد کنید، یا کار و سرگرمی را ازهم جدا کنید.</translation>
<translation id="8712767363896337380">‏تقریباً به‌روزرسانی شده است! برای تکمیل به‌روزرسانی، Egon را راه‌اندازی مجدد کنید.</translation>
<translation id="873133009373065397">‏Egon Browser نمی‌تواند مرورگر پیش‌فرض را تعیین یا تنظیم کند</translation>
<translation id="8821043148920470810">‏برای دریافت به‌روزرسانی‌های آتی Egon Browser، باید Windows 10 یا بالاتر داشته باشید. این رایانه از Windows 7 استفاده می‌کند.</translation>
<translation id="8823341990149967727">‏نسخه Egon قدیمی است</translation>
<translation id="8825634023950448068">‏برای محافظت از حریم خصوصی شما، علایقی را که قدیمی‌تر از ۴ هفته باشند به‌طور خودکار حذف می‌کنیم. وقتی به مرور کردن ادامه می‌دهید، ممکن است علاقه‌ای مجدداً به فهرست اضافه شود. و اگر Egon به‌اشتباه علاقه‌ای را اضافه کند یا شما نخواهید آگهی‌های مشخصی را ببینید، می‌توانید آن علاقه را بردارید.</translation>
<translation id="8834965163890861871">‏Egon Browser می‌خواهد گذرواژه‌ها را ویرایش کند. برای اینکه اجازه دهید این کار انجام شود، گذرواژه Windows خود را تایپ کنید.</translation>
<translation id="884296878221830158">‏این برنامه همچنین صفحه‌ای را که هنگام راه‌اندازی Egon یا کلیک کردن روی دکمه صفحه اصلی نشان داده می‌شود، کنترل می‌کند.</translation>
<translation id="8847000024471094355">‏Egon غیرفعال است</translation>
<translation id="8862326446509486874">شما حقوق لازم برای نصب در سطح سیستم را ندارید. دوباره به‌عنوان سرپرست نصب‌کننده را اجرا کنید.</translation>
<translation id="8914504000324227558">‏راه‌اندازی مجدد Egon</translation>
<translation id="8922193594870374009">‏برای ارسال شماره از <ph name="ORIGIN" /> به تلفن Android خود، در هر دو دستگاه به سیستم Egon وارد شوید.</translation>
<translation id="8983720963221508955">‏«مرور ایمن پیشرفته» را در حسابتان روشن کرده‌اید. اکنون آن را برای Egon دریافت کنید.</translation>
<translation id="8986207147630327271">با این کار، نمایه کاری را به این مرورگر اضافه می‌کنید و فقط کنترل نمایه کاری را دراختیار سرپرست قرار می‌دهید.</translation>
<translation id="8989968390305463310">‏سابقه مرور شما بر آگهی‌هایی که می‌بینید و علایقتان که در زیر برآورد شده است تأثیر می‌گذارد. برای محافظت از حریم خصوصی شما، Egon علایقتان را هر ماه به‌طور خودکار و چرخشی حذف می‌کند. ممکن است علایق بازآوری شود، مگر اینکه آن‌ها را بردارید.</translation>
<translation id="8999208279178790196">{0,plural, =0{‏به‌روزرسانی Egon دردسترس است}=1{‏به‌روزرسانی Egon دردسترس است}one{‏به‌روزرسانی Egon از # روز پیش دردسترس است}other{‏به‌روزرسانی Egon از # روز پیش دردسترس است}}</translation>
<translation id="9003498785844995646">‏وقتی روشن باشد، Egon با محدود کردن فعالیت پس‌زمینه و جلوه‌های بصری، مثل پیمایش روان و نرخ فریم ویدیو، در مصرف باتری صرفه‌جویی می‌کند. <ph name="BEGIN_LINK" />اطلاعات بیشتری کسب کنید<ph name="END_LINK" /> یا <ph name="BEGIN_LINK_2" />بازخورد ارسال کنید<ph name="END_LINK_2" /></translation>
<translation id="9053892488859122171">‏سیستم ChromeOS Flex</translation>
<translation id="9067395829937117663">‏Egon Browser به Windows 7 یا بالاتر نیاز دارد.</translation>
<translation id="911206726377975832">داده‌های مرور شما نیز حذف شود؟</translation>
<translation id="9138603949443464873">‏برای اعمال تغییراتتان، Egon را راه‌اندازی مجدد کنید</translation>
<translation id="9195993889682885387">‏Egon می‌توانند علایقتان را براساس سابقه مرور چند هفته گذشته برآورد کند. این اطلاعات از دستگاهتان خارج نمی‌شود.</translation>
<translation id="919706545465235479">‏به‌روزرسانی Egon برای شروع همگام‌سازی</translation>
<translation id="922152298093051471">‏سفارشی کردن Egon</translation>
<translation id="93760716455950538">‏بازراه‌اندازی ChromeOS Flex</translation>
<translation id="940313311831216333">‏برای دسترسی به چیزهای Egon در همه دستگاه‌هایتان، به سیستم وارد شوید، سپس همگام‌سازی را روشن کنید.</translation>
<translation id="989369509083708165">‏Egon Browser مرورگر پیش‌فرضتان است</translation>
<translation id="989816563149873169">‏با <ph name="SHORTCUT" /> می‌توانید بین نمایه‌های Egon جابه‌جا شوید</translation>
</translationbundle>