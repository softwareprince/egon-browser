<!DOCTYPE translationbundle>
<translationbundle lang="kk">
<translation id="1001534784610492198">Орнатқыш мұрағаты бүлінген немесе жарамсыз. Egon Browser қайтадан жүктеңіз.</translation>
<translation id="1026101648481255140">Орнатуды жалғастыру</translation>
<translation id="102763973188675173">Egon Browser браузерін реттеңіз және басқарыңыз. Жаңартылған нұсқа қолжетімді.</translation>
<translation id="1051826050538111504">Компьютеріңізде зиянды бағдарламалық құрал бар. Egon браузері оны өшіріп, параметрлеріңізді қалпына келтіреді де, кеңейтімдерді ажыратады. Соның арқасында браузеріңіз қалыпты жұмысын  жалғастырады.</translation>
<translation id="1065672644894730302">Реттеулерді оқу мүмкін емес.

Кейбір мүмкіндіктер қолжетімсіз болуы мүмкін және параметрлерге жасалған өзгертулер сақталмайды.</translation>
<translation id="1088300314857992706"><ph name="USER_EMAIL_ADDRESS" /> бұрын Egon браузерін пайдаланған</translation>
<translation id="110877069173485804">Сізге арналған Egon</translation>
<translation id="1125124144982679672">Egon браузерін кім пайдаланып жатыр?</translation>
<translation id="1142745911746664600">Egon браузерін жаңарту мүмкін емес</translation>
<translation id="1152920704813762236">ChromeOS туралы</translation>
<translation id="1154147086299354128">&amp;Egon браузерінде ашу</translation>
<translation id="1203500561924088507">Орнатқаныңыз үшін рақмет. <ph name="BUNDLE_NAME" /> пайдаланбас бұрын браузерді жауып, қайта ашуыңыз керек.</translation>
<translation id="1236866257838264361">Egon-ды толық қолдануға болады.</translation>
<translation id="1278833599417554002">&amp;Egon-ды жаңарту үшін қайта іске қосу</translation>
<translation id="1302523850133262269">Egon ең соңғы жүйе жаңартуларын орнатуда, күте тұрыңыз.</translation>
<translation id="1335640173511558774">Бұл құрылғыны пайдаланбас бұрын, <ph name="MANAGER" /> келесі Қызмет көрсету шарттарын оқып, қабылдауыңызды талап етеді. Бұл шарттар Google ChromeOS Flex Шарттарын толықтырмайды, өзгертпейді және шектемейді.</translation>
<translation id="1363996462118479832">Кіру кезіндегі қате салдарынан ChromeOS жүйесі деректеріңізді синхрондай алмады.</translation>
<translation id="137466361146087520">Egon Browser Beta</translation>
<translation id="1399397803214730675">Бұл компьютерге ең жаңа Egon Browser нұсқасы орнатылған. Бағдарламалық жасақтама жұмыс істемесе, Egon Browser браузерін жойып, әрекетті қайталап көріңіз.</translation>
<translation id="139993653570221430">Таңдауыңызды кез келген уақытта Egon параметрлерінде өзгертуге болады. Сынақ нұсқалары жарнама көрсетудің ағымдағы әдісімен жұмыс істейді. Сондықтан өзгерістер бірден көрінбейді.</translation>
<translation id="1434626383986940139">Egon Canary қолданбалары</translation>
<translation id="1507198376417198979">Жаңа Egon профиліңізді реттеңіз.</translation>
<translation id="1516530951338665275">Жұптауды жалғастыру үшін Egon Browser-ға Bluetooth-ты пайдалану рұқсаты керек. <ph name="IDS_BLUETOOTH_DEVICE_CHOOSER_AUTHORIZE_BLUETOOTH_LINK" /></translation>
<translation id="1547295885616600893">ChromeOS жүйесі <ph name="BEGIN_LINK_CROS_OSS" />ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS" /> арқылы қолжетімді болады.</translation>
<translation id="1553358976309200471">Egon жаңарту</translation>
<translation id="1583073672411044740"><ph name="EXISTING_USER" /> бұл Egon профиліне кіріп қойған. <ph name="USER_EMAIL_ADDRESS" /> үшін жаңа Egon профилі жасалады.</translation>
<translation id="1587223624401073077">Egon Browser камераңызды пайдалануда.</translation>
<translation id="1587325591171447154"><ph name="FILE_NAME" /> қауіпті болғандықтан, Egon оны бөгеді.</translation>
<translation id="1597911401261118146">Құпия сөздеріңіз ұрланудан және басқа да қауіпсіздік мәселелерінен қаншалықты қорғалғанын тексеру үшін <ph name="BEGIN_LINK" />Egon браузеріне кіріңіз<ph name="END_LINK" />.</translation>
<translation id="1599904803480101533">Осы мұрағат файлында зиянды бағдарлама жасырылуы мүмкін болғандықтан, Egon оны бөгеді.</translation>
<translation id="1619887657840448962">Egon браузерін қауіпсіз ету үшін, <ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> тізімінде жоқ келесі кеңейтім  өшірілді, ол сізге ескертілмей қосылған болуы мүмкін.</translation>
<translation id="1627304841979541023"><ph name="BEGIN_BOLD" />Дерек қалай басқарылады:<ph name="END_BOLD" /> құпиялылығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Egon-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="1628000112320670027">Egon жөнінде анықтама алу</translation>
<translation id="1640672724030957280">Жүктеп алынып жатыр…</translation>
<translation id="1662146548738125461">ChromeOS Flex туралы ақпарат</translation>
<translation id="1674870198290878346">Сілтемені Egon инкогнито терезесінде ашу</translation>
<translation id="1682634494516646069">Egon Browser өзінің деректер каталогін оқуы және жазуы мүмкін емес:

<ph name="USER_DATA_DIRECTORY" /></translation>
<translation id="1691802391966922744">{COUNT,plural, =1{Әкімшіңіз Egon әрекетсіз режимде 1 минуттан көп уақыт тұрса, оны жабылатын күйге конфигурациялаған.}other{Әкімшіңіз Egon әрекетсіз режимде # минуттан көп уақыт тұрса, оны жабылатын күйге конфигурациялаған.}}</translation>
<translation id="1698376642261615901">Egon Browser веб-беттер мен қолданбаларды өте жылдам пайдаланатын веб-браузер болып табылады. Ол жылдам, тұрақты және пайдалануға оңай. Egon Browser ендірілген зиянды бағдарлама және фишинг қорғанысымен интернетті қауіпсіз шарлаңыз.</translation>
<translation id="1713301662689114961">{0,plural, =1{Egon браузері бір сағаттан кейін қайта іске қосылады}other{Egon браузері # сағаттан кейін қайта іске қосылады}}</translation>
<translation id="1734234790201236882">Egon бұл құпия сөзді Google аккаунтыңызда сақтайды. Оны есте сақтаудың қажеті жоқ.</translation>
<translation id="1759842336958782510">Egon</translation>
<translation id="1786003790898721085"><ph name="TARGET_DEVICE_NAME" /> құрылғысындағы Egon браузеріне кіргеніңізді тексеріп, қайта жіберіп көріңіз.</translation>
<translation id="1812689907177901597">Бұл функцияны өшіріп, Egon браузеріне кірместен Gmail сияқты Google сайттарын пайдалана беруіңізге болады</translation>
<translation id="1860536484129686729">Egon браузеріне бұл сайтта камераны пайдалану үшін рұқсат керек</translation>
<translation id="1873233029667955273">Egon Browser әдепкі браузеріңіз емес</translation>
<translation id="1874309113135274312">Egon Browser Beta (mDNS-In)</translation>
<translation id="1877026089748256423">Egon ескірген</translation>
<translation id="1919130412786645364">Egon браузеріне кіруге рұқсат ету</translation>
<translation id="1952239763774043237">Egon Browser-ның жаңа нұсқаларын алып тұру үшін macOS 10.13 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде macOS 10.12 нұсқасы орнатылған.</translation>
<translation id="1953553007165777902">Жүктеп алынып жатыр… <ph name="MINUTE" /> минут қалды.</translation>
<translation id="2018528049276128029">Әр профильде бетбелгілер, тарих, құпия сөздер және тағы басқа Egon ақпараты бар.</translation>
<translation id="2018879682492276940">Орнатылмады. Қайталап көріңіз.</translation>
<translation id="2071318482926839249">Басқа аккаунт кіріп қойған. Браузерді пайдалану тарихын бөлек сақтау үшін Egon сізге жеке профиль жасай алады.</translation>
<translation id="207902854391093810">Сынақ нұсқалары қосылғанда, жарнама өлшеу функциясы сіз кіретін сайттарға өз жарнамаларының өнімділігін өлшеуге көмектесетін ақпаратты Egon браузерінен сұратуға мүмкіндік береді. Сайттар бір-біріне барынша аз ақпарат жіберетіндіктен, сайтаралық бақылау шектеледі.</translation>
<translation id="2091012649849228750">Egon Browser-ның жаңа нұсқаларын алып тұру үшін Windows 10 не одан кейінгі операциялық жүйе керек болады. Бұл компьютерде Windows 8 нұсқасы орнатылған.</translation>
<translation id="2094648590148273905">ChromeOS Flex шарттары</translation>
<translation id="2094919256425865063">Egon браузерінен бәрібір шығасыз ба?</translation>
<translation id="2106831557840787829">ChromeOS Flex операциялық жүйесі де <ph name="BEGIN_LINK_LINUX_OSS" />Linux әзірлеу ортасы<ph name="END_LINK_LINUX_OSS" /> сияқты қосымша <ph name="BEGIN_LINK_CROS_OSS" />ашық кодты бағдарламалық құрал<ph name="END_LINK_CROS_OSS" /> арқылы қолжетімді болады.</translation>
<translation id="2120620239521071941"><ph name="ITEMS_COUNT" /> элемент бұл құрылғыдан жойылады. Деректерді кейінірек алу үшін Egon жүйесіне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="2121284319307530122">&amp;Egon-ды жаңарту үшін қайта іске қосу</translation>
<translation id="2123055963409958220"><ph name="BEGIN_LINK" />Ағымдағы параметрлерді<ph name="END_LINK" /> хабарлау арқылы Egon браузерін жақсартуға көмектесіңіз</translation>
<translation id="2131230230468101642">Құпиялылығыңызды сақтау үшін 4 аптадан көп көрсетілген қызығушылықтарды автоматты түрде жойып отырамыз. Интернетті шолу кезінде белгілі бір қызығушылық тізімде қайтадан шығуы мүмкін. Бұл ретте Egon-ның ескергенін қаламаған қызығушылықтарды өшіруге болады.</translation>
<translation id="2139300032719313227">ChromeOS жүйесін өшіріп қосу</translation>
<translation id="2151406531797534936">Egon браузерін өшіріп, қайта қосыңыз</translation>
<translation id="2174917724755363426">Орнату аяқталмады. Шынымен бас тартқыңыз келе ме?</translation>
<translation id="223889379102603431">Egon-нің түбірлік сертификаттарды қалай басқаратыны туралы ақпарат</translation>
<translation id="2258103955319320201">Egon браузерінің материалдарын барлық құрылғыда пайдалану үшін аккаунтқа кіріп, синхрондау параметрін қосыңыз.</translation>
<translation id="2290014774651636340">Google API пернелері жоқ. Кейбір Egon Browser функционалдықтары өшіріледі.</translation>
<translation id="2290095356545025170">Egon Browser жою қажет пе?</translation>
<translation id="2309047409763057870">Бұл – Egon Browser браузерінің қайта орнатылған нұсқасы және әдепкі браузер бола алмайды.</translation>
<translation id="2345992953227471816">Egon бұл кеңейтімдерде зиянды бағдарлама бар екенін анықтады:</translation>
<translation id="2348335408836342058">Egon браузеріне бұл сайтта камераны және микрофонды пайдалану үшін рұқсат керек</translation>
<translation id="234869673307233423">Egon сіздің құпия сөздеріңізді тексере алмайды. Кейінірек қайталап көріңіз.</translation>
<translation id="235650106824528204">Жұмыс профилінің әкімшісі осы профильді пайдалану кезінде құрылатын Egon браузерінің кез келген дерегін (бетбелгілер, тарих, құпия сөздер жасау және басқа параметрлер сияқты) жоя алады. <ph name="LEARN_MORE" /></translation>
<translation id="2359808026110333948">Жалғастыру</translation>
<translation id="2401189691232800402">ChromeOS жүйесі</translation>
<translation id="2467438592969358367">Egon Browser құпия сөздерді экспорттағысы келеді. Бұған рұқсат беру үшін Windows құпия сөзіңізді теріңіз.</translation>
<translation id="2485422356828889247">Жою</translation>
<translation id="2494974097748878569">Egon браузеріндегі Google Assistant</translation>
<translation id="2534507159460261402">Google Pay (Egon браузеріне көшірілген)</translation>
<translation id="2559253115192232574">Кейін сіз кірген сайт жарнамаларды жекелендіру үшін Egon браузерінен қызығушылықтарыңыз туралы ақпаратты сұрап алады. Egon браузері ең көбі 3 қызығушылықты бөлісуі мүмкін.</translation>
<translation id="2563121210305478421">Egon қайта іске қосылсын ба?</translation>
<translation id="2574930892358684005"><ph name="EXISTING_USER" /> бұл Egon профиліне кіріп қойған. Браузерді пайдалану деректерін бөлек сақтау үшін Egon сізге жеке профиль жасай алады.</translation>
<translation id="2580411288591421699">Қазір ашылып тұрғанмен бірдей Egon Browser нұсқасын орнату мүмкін емес. Egon Browser браузерін жауып, әрекетті қайталаңыз.</translation>
<translation id="2586406160782125153">Құрылғыдан шолу деректері жойылады. Деректерді кейінірек алу үшін Egon жүйесіне <ph name="USER_EMAIL" /> болып кіріңіз.</translation>
<translation id="2597976513418770460"><ph name="ACCOUNT_EMAIL" /> аккаунтынан Egon браузерінің мәліметтерін алыңыз.</translation>
<translation id="2622559029861875898">Egon жаңа нұсқалардың бар-жоғын тексере алмайды. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="2645435784669275700">ChromeOS</translation>
<translation id="2652691236519827073">Сілтемені жаңа Egon қойындысында ашу</translation>
<translation id="2665296953892887393">Google компаниясына ақау есептерін және <ph name="UMA_LINK" /> жіберу арқылы Egon Browser жақсартуға көмектесіңіз</translation>
<translation id="2689103672227170538">Бұл кеңейтім Egon браузерін іске қосқан кезде көрсетілетін бетті өзгертті.</translation>
<translation id="2742320827292110288">Ескерту: Egon Browser кеңейтімдердің браузерді қолдану тарихын жазуына кедергі бола алмайды. Бұл кеңейтімді Инкогнито режимінде өшіру үшін бұл опцияның белгісін алып тастаңыз.</translation>
<translation id="2765403129283291972">Egon браузеріне бұл сайтта микрофонды пайдалану үшін рұқсат керек</translation>
<translation id="2770231113462710648">Әдепкі браузерді келесіге өзгерту:</translation>
<translation id="2775140325783767197">Egon сіздің құпия сөздеріңізді тексере алмайды. Интернет байланысын тексеріп көріңіз.</translation>
<translation id="2799223571221894425">Қайта іске қосу</translation>
<translation id="2847461019998147611">Egon Browser жүйесін осы тілде көрсету</translation>
<translation id="2857540653560290388">Egon қосылып жатыр…</translation>
<translation id="2857972467023607093">Бұл аккаунтқа Egon профилі тіркеліп қойған.</translation>
<translation id="2861074815332034794">Egon жаңартылуда (<ph name="PROGRESS_PERCENT" />)</translation>
<translation id="2871893339301912279">Egon жүйесіне кірдіңіз!</translation>
<translation id="2885378588091291677">Тапсырмалар реттегіші</translation>
<translation id="2888126860611144412">Egon туралы</translation>
<translation id="2915996080311180594">Кейін қайта қосу</translation>
<translation id="2926676257163822632">Құпия сөзіңіз оңай болса, оны табу да оңай. Egon браузеріне <ph name="BEGIN_LINK" />күрделі құпия сөздер жасауға және сақтауға<ph name="END_LINK" /> мүмкіндік беріңіз.</translation>
<translation id="2926952073016206995">Egon бұл сайт үшін камераны пайдалануға рұқсат сұрайды.</translation>
<translation id="2928420929544864228">Орнату аяқталды.</translation>
<translation id="2929907241665500097">Egon жаңартылған жоқ. Бірдеңе дұрыс болмады. <ph name="BEGIN_LINK" />Egon браузеріндегі жаңартуға қатысты мәселелерді түзетіңіз.<ph name="END_LINK" /></translation>
