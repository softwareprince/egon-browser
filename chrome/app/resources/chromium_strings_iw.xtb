<translation id="7828947555739565424">‏כבר קיים במכשיר פרופיל Egon עם החשבון הזה.</translation>
<translation id="7845233973568007926">תודה שהתקנת. עליך להפעיל מחדש את המחשב לפני השימוש ב-<ph name="BUNDLE_NAME" />.</translation>
<translation id="7867198900892795913">‏עדכון Egon לגרסה האחרונה לא הצליח, ולכן אין לך גישה אל תכונות חדשות ותיקוני אבטחה.</translation>
<translation id="7872446069773932638">מתבצעת הורדה… יש עוד <ph name="SECONDS" /> שנ'</translation>
<translation id="7877292582355102282">‏<ph name="BEGIN_BOLD" />איך ניתן לנהל את הנתונים שלך:<ph name="END_BOLD" /> כדי להגן על הפרטיות שלך, תחומי עניין שהוגדרו לפני יותר מ-4 שבועות נמחקים אוטומטית. עם המשך הגלישה, תחום עניין כלשהו עשוי להופיע שוב ברשימה. יש גם אפשרות להסיר תחומי עניין מ-Egon כדי שלא יילקחו בחשבון.</translation>
<translation id="7937630085815544518">‏נכנסת ל-Egon כ-<ph name="USER_EMAIL_ADDRESS" />. יש להשתמש באותו חשבון כדי להיכנס שוב.</translation>
<translation id="7975919845073681630">‏זוהי התקנה משנית של Egon, ולא ניתן להפוך אותו לדפדפן ברירת המחדל שלך.</translation>
<translation id="7997934263947464652">‏תוספים, אפליקציות ועיצובים ממקורות לא מוכרים עלולים להזיק למכשיר. ההמלצה של Egon היא להתקין אותם רק מ<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /></translation>
<translation id="8013436988911883588">‏אחרי מתן גישה ל-Egon, אתרים יוכלו לבקש ממך גישה.</translation>
<translation id="80471789339884597">תודה שהתקנת. עליך להפעיל מחדש את כל הדפדפנים לפני השימוש ב-<ph name="BUNDLE_NAME" />.</translation>
<translation id="8105840573057009683">‏נדרשת הרשאת מיקום ב-Egon עבור האתר הזה</translation>
<translation id="8133124826068723441">‏לא בוצע סנכרון של הנתונים ב-ChromiumOS כי אפשרות הסנכרון לא זמינה עבור הדומיין שלך.</translation>
<translation id="813913629614996137">מתבצע אתחול...</translation>
<translation id="81770708095080097">‏Egon‏ חסם את הקובץ הזה כי הוא מסוכן.</translation>
<translation id="8213374284266571500">‏סוג הקובץ הזה מסוכן ולכן הקובץ נחסם על ידי Egon</translation>
<translation id="8248265253516264921">‏אם אין לתמונה תיאור מועיל, Egon ינסה לספק לך תיאור. כדי ליצור תיאורים, התמונות נשלחות אל Google. אפשר להשבית את האפשרות הזו בכל זמן דרך ההגדרות.</translation>
<translation id="8266560134891435528">‏Egon לא יכול לבדוק את הסיסמאות שלך כי לא נכנסת לחשבון</translation>
<translation id="8276522524898344151">‏Egon מנסה להעתיק את הסיסמאות.</translation>
<translation id="8290862415967981663">‏Egon‏ חסם את הקובץ הזה כי הוא עלול להיות מסוכן.</translation>
<translation id="8330519371938183845">‏כניסה לחשבון תסנכרן ותתאים אישית את Egon בכל המכשירים שברשותך</translation>
<translation id="8340674089072921962">‏בכתובת <ph name="USER_EMAIL_ADDRESS" /> השתמשו בעבר ב-Egon</translation>
<translation id="8357820681460164151">‏כדי לגשת אל פריטים שונים בדפדפן Egon שלך מכל המכשירים, צריך להיכנס לחשבון ולהפעיל את הסנכרון</translation>
<translation id="8360718212975266891">‏כדי לקבל עדכונים של Egon בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.</translation>
<translation id="8417404458978023919">{0,plural, =1{‏צריך להפעיל מחדש את Egon בתוך יום אחד}one{‏צריך להפעיל מחדש את Egon בתוך # ימים}two{‏צריך להפעיל מחדש את Egon בתוך # ימים}other{‏צריך להפעיל מחדש את Egon בתוך # ימים}}</translation>
<translation id="8453117565092476964">‏הארכיון של המתקין פגום או שאינו חוקי. יש להוריד שוב את Egon.</translation>
<translation id="8463672209299734063">‏אופציונלי: שליחה אוטומטית של נתוני אבחון ונתוני שימוש במכשיר אל Google תעזור לשפר את התכונות ואת הביצועים של ChromiumOS.</translation>
<translation id="8493179195440786826">‏Egon אינו מעודכן</translation>
<translation id="8550334526674375523">פרופיל העבודה שלך נפרד לחלוטין מהפרופיל האישי שלך.</translation>
<translation id="8558383651099478961">‏אחד מההורים השבית ב-Egon את ההגדרה "הרשאות לאתרים, אפליקציות ותוספים". לא ניתן להוסיף את ה<ph name="EXTENSION_TYPE_PARAMETER" />.</translation>
<translation id="8561285221328166383">‏כדי לקבל עדכונים של Egon בעתיד, צריך להשתמש ב-macOS מגרסה 10.13 ואילך. במחשב הזה מותקנת מערכת ההפעלה macOS 10.12.</translation>
<translation id="8568283329061645092">‏Egon יכול לבדוק את הסיסמאות כשנכנסים באמצעות חשבון Google</translation>
<translation id="8574036838419011058">‏כשהתכונה מופעלת, Egon חוסך בחיי הסוללה על ידי הגבלת הפעילות ברקע והאפקטים החזותיים, כמו גלילה חלקה וקצב פריימים של סרטונים. <ph name="BEGIN_LINK" />מידע נוסף<ph name="END_LINK" /></translation>
<translation id="8586442755830160949">‏Copyright <ph name="YEAR" /> The Egon Authors. כל הזכויות שמורות.</translation>
<translation id="8608079656141766906">‏<ph name="BEGIN_BOLD" />אופן השימוש בנתונים האלה:<ph name="END_BOLD" /> אתרים יכולים לשמור מידע ב-Egon לגבי תחומי העניין שלך. לדוגמה, אם ביקרת באתר כדי לקנות נעליים למרתון, האתר עשוי להגדיר 'ריצת מרתון' כתחום עניין שלך. לאחר מכן, בביקור באתר שונה, למשל כדי להירשם למרוץ, יכול להיות שתוצג לך מודעה לנעלי ריצה על סמך תחומי העניין שלך.</translation>
<translation id="8619360774459241877">‏הפעלת Egon מתבצעת...</translation>
<translation id="8621669128220841554">‏ההתקנה נכשלה בשל שגיאה לא מזוהה. יש להוריד שוב את Egon.</translation>
<translation id="8697124171261953979">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Egon או מבצעים חיפוש מסרגל הכתובות.</translation>
<translation id="8704119203788522458">‏זהו ה-Egon שלך</translation>
<translation id="8713679423359107094">‏אחרי שסוגרים את כל החלונות של Egon, קובצי cookie ונתוני אתרים נמחקים אוטומטית</translation>
<translation id="8796443464227412154">‏המערכת <ph name="BEGIN_BOLD" />תוציא אותך מהחשבון ברוב האתרים<ph name="END_BOLD" /> עם סגירת Egon. אם הסנכרון כבוי, המערכת <ph name="BEGIN_BOLD" />תוציא אותך מהחשבון גם בשירותי Google וב-Egon<ph name="END_BOLD" />.</translation>
<translation id="8796602469536043152">‏Egon זקוק להרשאת גישה אל המצלמה והמיקרופון בשביל האתר הזה</translation>
<translation id="8833697763442816810">‏מערכת ChromiumOS</translation>
<translation id="8846118132221683440">‏<ph name="BEGIN_BOLD" />באילו נתונים נעשה שימוש:<ph name="END_BOLD" /> היסטוריית הגלישה – תיעוד האתרים שביקרת בהם באמצעות Egon במכשיר הזה.</translation>
<translation id="8862326446509486874">אין לך זכויות שמתאימות להתקנה ברמת המערכת. יש לנסות להפעיל שוב את המתקין כמנהל מערכת.</translation>
<translation id="8880203542552872219">‏אם שינית את הסיסמה הזו, יש לערוך את הסיסמה השמורה ב-Egon כך שהיא תתאים לסיסמה החדשה שלך.</translation>
<translation id="8897323336392112261">‏הגדרה זו גם קובעת איזה דף מוצג כשמפעילים את Egon או לוחצים על הלחצן 'דף הבית'.</translation>
<translation id="8907580949721785412">‏Egon מנסה להציג סיסמאות. יש להקליד את הסיסמה שלך ל-Windows כדי לאפשר זאת.</translation>
<translation id="8931379085695076764">‏Egon יכול להעריך מהם תחומי העניין שלך על סמך היסטוריית הגלישה שלך מהשבועות האחרונים. המידע הזה נשאר במכשיר שלך.</translation>
<translation id="8941642502866065432">‏לא ניתן לעדכן את Egon</translation>
<translation id="897581876605952338">‏הלוגו של Egon Enterprise</translation>
<translation id="8986207147630327271">בחרת להוסיף פרופיל עבודה לדפדפן זה ולתת למנהל המערכת שליטה רק על פרופיל העבודה.</translation>
<translation id="9019929317751753759">‏כדי לשפר את האבטחה של Egon, השבתנו את התוסף הבא שאינו רשום ב-<ph name="IDS_EXTENSION_WEB_STORE_TITLE" /> וייתכן שנוסף ללא ידיעתך.</translation>
<translation id="9022552996538154597">‏כניסה אל Egon</translation>
<translation id="9089354809943900324">‏Egon אינו מעודכן</translation>
<translation id="9093206154853821181">{0,plural, =1{‏Egon יופעל מחדש בעוד שעה}one{‏Egon יופעל מחדש בעוד # שעות}two{‏Egon יופעל מחדש בעוד # שעות}other{‏Egon יופעל מחדש בעוד # שעות}}</translation>
<translation id="9106612006984859720">‏כדי לקבל עדכונים של Egon בעתיד, צריך להשתמש ב-Windows מגרסה 10 ואילך. במחשב הזה פועלת מערכת Windows 8.1.</translation>
<translation id="91086099826398415">‏פתיחת הקישור &amp;בכרטיסיית Egon חדשה</translation>
<translation id="911206726377975832">למחוק גם את נתוני הגלישה שלך?</translation>
<translation id="9144490074902256427">‏במהלך הפעולה של גרסאות הניסיון, תהיה לך אפשרות לראות ולהסיר את תחומי העניין שלפיהם האתרים הציגו לך את המודעות. ההערכה של תחומי העניין ב-Egon מתבססת על היסטוריית הגלישה שלך מהזמן האחרון.</translation>
<translation id="9158494823179993217">‏לפי הגדרת מנהל המערכת, Egon יפתח דפדפן חלופי כדי לגשת אל <ph name="TARGET_URL_HOSTNAME" />.</translation>
<translation id="9185526690718004400">‏הפעלה מחדש לצורך עדכון &amp;Egon</translation>
<translation id="9190841055450128916">‏Egon ‏(mDNS-In)</translation>
<translation id="93478295209880648">‏ייתכן ש-Egon לא יפעל כראוי כי הוא כבר לא נתמך ב-Windows XP וב-Windows Vista</translation>
<translation id="942598560705308788">‏אישורים שמנוהלים על ידי Egon</translation>
<translation id="945990405696787151">‏כדי לקבל עדכונים של Egon בעתיד, צריך להשתמש ב-macOS מגרסה 10.13 ואילך. במחשב הזה פועלת מערכת ההפעלה ‎OS X 10.11.</translation>
<translation id="965162752251293939">‏מי משתמש/ת ב-Egon?</translation>
<translation id="967427899662692980">‏רוצה להשיג את רמת האבטחה הגבוהה ביותר של Egon?</translation>
<translation id="985602178874221306">‏מחברי Egon</translation>
</translationbundle>