<translation id="7118091470949186573">‏اب جب بھی آپ پیغامات، دستاویزات اور دیگر ایپس میں لنکس کو تھپتھپائیں تو آپ Egon استعمال کرسکتے ہیں۔</translation>
<translation id="7175400662502680481">ڈیٹا کی خلاف ورزی میں آپ کا پاس ورڈ افشاء ہو گیا۔ پاس ورڈ مینیجر اسے ابھی تبدیل کرنے کی تجویز کرتا ہے۔</translation>
<translation id="7208566199746267865">‏Egon آپ کے اکاؤنٹس کو ویب پر لا کر آپ کا وقت بچاتا ہے۔ آپ ترتیبات میں اکاؤنٹس کو شامل کر سکتے یا ہٹا سکتے ہیں۔</translation>
<translation id="725427773388857052">‏Egon آپ کو ڈیٹا کی خلاف ورزیوں، غیر محفوظ ویب سائٹس اور بہت کچھ سے محفوظ رکھنے میں مدد کر سکتا ہے۔</translation>
<translation id="7255976941681861701">‏نئے Egon مینو کو جانیں</translation>
<translation id="7269362888766543920">‏کچھ اضافے Egon کے کریش ہونے کا سبب بنتے ہیں۔ براہ کرم ان کو اَن انسٹال کرنے کی کوشش کریں۔</translation>
<translation id="7313655110045230863">‏Egon کو اپنا ڈیفالٹ براؤزر بنانے کے لئے، ترتیبات کھولیں۔ ڈیفالٹ براؤزر ایپ پر تھپتھپائیں اور پھر Egon منتخب کریں۔</translation>
<translation id="7337881442233988129">Egon</translation>
<translation id="7357211569052832586">‏Egon اور مطابقت پذیر آلات سے منتخب ڈیٹا کو ہٹا دیا گیا ہے۔ ممکن ہے کہ history.google.com پر آپ کے Google اکاؤنٹ میں دیگر Google سروسز سے تلاشیں اور سرگرمی جیسی براؤزنگ کی سرگزشت کی دیگر شکلیں موجود ہوں۔</translation>
<translation id="7395825497086981028">آپ کا پاس ورڈ <ph name="EMAIL" /> کے لیے پاس ورڈ مینیجر میں محفوظ کیا جائے گا۔</translation>
<translation id="7400689562045506105">‏Egon کو ہر جگہ استعمال کریں</translation>
<translation id="766897673682622022">‏ڈیٹا کی خلاف ورزی میں آپ کا پاس ورڈ افشاء ہو گیا۔ Egon کی تجویز ہے کہ آپ ابھی پاس ورڈ تبدیل کریں۔</translation>
<translation id="7674213385180944843">‏ترتیبات &gt; رازداری &gt; کیمرا &gt; Egon کو کھولیں اور کیمرا آن کریں۔</translation>
<translation id="7746854981345936341">‏Egon تجویز۔ واپس جائیں، فارورڈ کریں، اور تلاش کریں جیسے بعض بٹنز اب آپ کی اسکرین کے نیچے ہیں۔</translation>
<translation id="7763454117143368771">‏خطرناک سائٹس سے محفوظ رہنے اور اپنے پاس ورڈز کو محفوظ رکھنے کیلئے، Egon کا اپنے ڈیفالٹ براؤزر کے طور پر استعمال کریں</translation>
<translation id="7812317783196516890">‏آپ سائن ان ہیں اور اپنے ڈیٹا کو <ph name="DOMAIN" /> کے زیر انتظام اکاؤنٹ کے ساتھ مطابقت پذیر بنا رہے ہیں جس کا منتظم اب اس اکاؤنٹ کے لیے مخصوص صارف پالیسیاں ترتیب دے سکتا ہے جو Egon براؤزر کے رویے کو تبدیل کر سکتی ہیں۔</translation>
<translation id="786327964234957808">‏آپ مطابقت پذیری اکاؤنٹس کو <ph name="USER_EMAIL1" /> سے <ph name="USER_EMAIL2" /> پر سوئچ کر رہے ہیں۔ آپ کا موجودہ Egon ڈیٹا <ph name="DOMAIN" /> کے زیر انتظام ہے۔ اس سے آپ کا ڈیٹا اس آلہ سے حذف ہو جائے گا، لیکن آپ کا ڈیٹا <ph name="USER_EMAIL1" /> میں باقی رہے گا۔</translation>
<translation id="7890287942691234100">‏Egon اسکینر کا استعمال شروع کریں</translation>
<translation id="7928628054454574139">‏جب بھی آپ دیگر ایپس میں لنکس پر تھپتھپائیں تو انہیں Egon میں کھولیں</translation>
<translation id="7931842119211730154">‏جب آپ Egon کو بند کریں تو پوشیدگی ٹیبز کو مقفل کر دیں</translation>
<translation id="7980860476903281594">‏Egon آپ کے مقام کی معلومات کا اشتراک ان سائٹس کے ساتھ کرتا ہے جن کی آپ اجازت دیتے ہیں۔</translation>
<translation id="8013573822802650211">‏اپنے ٹیبز کو دیکھنے کے لئے جہاں بھی آپ Egon استعمال کرتے ہیں، اپنے تمام آلات پر سائن ان کریں</translation>
<translation id="8073677936375100957">‏اس آلہ سے آپ کا Egon ڈیٹا صاف کریں؟</translation>
<translation id="8240981428553046115">‏Egon اپ ڈیٹس چیک نہیں کر سکا۔ بعد میں دوبارہ کوشش کریں۔</translation>
<translation id="8308172444429103994">‏Egon کی تجویز۔ کی بورڈ کے اوپری حصے میں اپنا محفوظ کردہ پاس ورڈ منتخب کر کے تیزی سے سائن ان کریں۔</translation>
<translation id="8409374867500149834">‏آپ کے پاس نقصان دہ ویب سائٹس کے خلاف Egon کی مضبوط ترین سیکیورٹی ہے</translation>
<translation id="858114650497379505">‏آپ اپنے iPhone پر پاس ورڈ مینیجر میں اپنے محفوظ کردہ پاس ورڈز کو دیگر ایپس میں استعمال کر سکتے ہیں۔</translation>
<translation id="8586442755830160949">‏کاپی رائٹ ‎<ph name="YEAR" /> The Egon Authors۔ جملہ حقوق محفوظ۔</translation>
<translation id="865600487977764604">‏آپ کے سائن ان ہونے پر آپ کو Egon پر محفوظ رکھتا ہے اور دیگر Google ایپس میں آپ کی سیکیورٹی کو بہتر بنانے کے لیے استعمال کیا جا سکتا ہے</translation>
<translation id="8663480472502753423">‏Egon کو اپ ٹو ڈیٹ رکھیں</translation>
<translation id="8685813584220679697">‏اس سائٹ اور Egon پر سائن ان کریں۔</translation>
<translation id="8747378496147986285">‏آن ہونے پر:
<ph name="BEGIN_INDENT" />  • Egon کو ان لوگوں کے لیے بہتر بنانے میں مدد کریں جو اسے آپ کے طریقے سے استعمال کرتے ہیں۔<ph name="END_INDENT" />

غور کرنے کی چیزیں:
<ph name="BEGIN_INDENT" />  • آپ کے Egon کے استعمال کے بارے میں معلومات Google کو بھیجی جاتی ہے، لیکن یہ آپ سے منسلک نہیں ہے۔
  • اگر Egon کریش ہو جاتا ہے تو کریش کی تفصیلات میں کچھ ذاتی معلومات شامل ہو سکتی ہیں۔
  • اگر آپ مطابقت پذیری کو آن کرتے ہیں تو میٹرکس میں ان URLs کے بارے میں معلومات بھی شامل ہو سکتی ہیں جنہیں آپ ملاحظہ کرتے ہیں۔<ph name="END_INDENT" /></translation>
<translation id="8776843108004031667">‏اس اکاؤنٹ اور کسی بھی غیر محفوظ ڈیٹا کو Egon سے ہٹا دیا جائے گا۔</translation>
<translation id="894437814105052438">‏آپ کے سائن آؤٹ کرنے پر، Egon کوئی بھی نیا ڈیٹا آپ کے Google اکاؤنٹ کے ساتھ سِنک نہیں کرے گا۔ پہلے کا سِنک کردہ ڈیٹا اکاؤنٹ میں باقی رہے گا۔</translation>
<translation id="9022552996538154597">‏Egon میں سائن ان کریں</translation>
<translation id="9059693977935746710">آپ کو یہ پاس ورڈ یاد رکھنے کی ضرورت نہیں ہوگی۔ اسے پاس ورڈ مینیجر میں <ph name="EMAIL" /> کے لیے محفوظ کیا جائے گا</translation>
<translation id="9089354809943900324">‏Egon پرانا ہے</translation>
<translation id="9110075932708282655">‏بطور ڈیفالٹ Egon کا استعمال کریں</translation>
<translation id="921174536258924340">‏Egon سبھی پاس ورڈز چیک نہیں کر سکا۔ آئندہ کل دوبارہ کوشش کریں یا <ph name="BEGIN_LINK" />اپنے Google اکاؤنٹ میں پاس ورڈز چیک کریں۔<ph name="END_LINK" /></translation>
<translation id="985602178874221306">‏Egon مصنّفین</translation>
</translationbundle>